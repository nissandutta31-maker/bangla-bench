# BanglaBench API keys — copy this block into ~/.zshrc on your Mac, then:
#   source ~/.zshrc
#
# DeepSeek: reuse the same value as COPILOT_PROVIDER_API_KEY if you already have it.
export DEEPSEEK_API_KEY="paste-your-deepseek-key-here"
export OPENAI_API_KEY="sk-..."              # GPT-5.5
export ANTHROPIC_API_KEY="sk-ant-..."       # Claude Opus 4.8
export NVIDIA_API_KEY="nvapi-..."           # free at https://build.nvidia.com

# Optional — Bangla-native models (HF Inference Endpoints):
# export HF_TOKEN="hf_..."
# export HF_TITULLM_API_BASE="https://xxxxx.endpoints.huggingface.cloud"
# export HF_TIGERLLM_API_BASE="https://yyyyy.endpoints.huggingface.cloud"
